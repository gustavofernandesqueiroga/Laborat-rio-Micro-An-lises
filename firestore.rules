// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - name: string (optional) - User's full name
//   - email: string (required) - User's email
//   - role: string (required) - 'admin' or 'client'
//
// Collection: results
// Document ID: {protocol}
// Fields:
//   - protocol: string (required) - Unique protocol ID
//   - password: string (required) - Access password
//   - patientName: string (required) - Patient name
//   - date: string (required) - Collection date
//   - exams: list (required) - List of exam objects
//
// Collection: appointments
// Document ID: {appointmentId}
// Fields:
//   - type: string (required) - 'HOME' or 'LAB'
//   - serviceId: string (required) - Exam ID
//   - unitId: string (optional) - Unit ID
//   - date: string (required) - Appointment date
//   - time: string (required) - Appointment time
//   - name: string (required) - Patient name
//   - phone: string (required) - Patient phone
//   - email: string (required) - Patient email
//   - protocolId: string (required) - Generated protocol
//   - userUid: string (required) - User who scheduled
//   - createdAt: timestamp (required) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "gustavofernandesqueiroga@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['ADMIN', 'CLIENT', 'GUEPARDO', 'EAL', 'PARTNER', 'CLT', 'VISITOR', 'admin', 'client', 'guepardo', 'eal', 'partner'];
    }

    function isRole(role) {
      return isAuthenticated() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role.upper());
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['id', 'guepardoUid', 'customerUid', 'hearts', 'createdAt']) &&
             data.id is string &&
             data.guepardoUid is string &&
             data.customerUid == request.auth.uid &&
             data.hearts >= 1 && data.hearts <= 5 &&
             data.createdAt is timestamp;
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['id', 'name', 'quantity', 'type', 'ealUid', 'createdAt']) &&
             data.id is string &&
             data.name is string &&
             data.quantity is number &&
             data.type in ['entry', 'exit', 'checkout'] &&
             data.ealUid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['protocol', 'password', 'patientName', 'date', 'exams']) &&
             data.protocol is string &&
             data.password is string &&
             data.patientName is string &&
             data.exams is list;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['type', 'serviceId', 'date', 'time', 'name', 'phone', 'email', 'protocolId', 'userUid', 'createdAt']) &&
             data.type in ['HOME', 'LAB'] &&
             data.serviceId is string &&
             data.date is string &&
             data.time is string &&
             data.name is string &&
             data.phone is string &&
             data.email is string &&
             data.protocolId is string &&
             data.userUid == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('age' in data) || data.age is string) &&
             (!('gender' in data) || data.gender is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role in ['CLIENT', 'GUEPARDO', 'EAL', 'PARTNER', 'CLT', 'VISITOR', 'client', 'guepardo', 'eal', 'partner'] || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    // Guepardo Profiles
    match /guepardo_profiles/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Feedback collection
    match /feedback/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Materials collection
    match /materials/{materialId} {
      allow read: if isRole('eal') || isAdmin();
      allow create: if isRole('eal') && isValidMaterial(request.resource.data) || isAdmin();
      allow update, delete: if isRole('eal') || isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userUid == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (resource.data.userUid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userUid == request.auth.uid || isAdmin());
    }

    // Results collection
    match /results/{protocol} {
      // For the prototype, we allow reading if authenticated. 
      // In a real production app, we would restrict this further.
      allow read: if isAuthenticated(); 
      allow create, update, delete: if isAdmin();
    }

    // Appointments collection
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (resource.data.userUid == request.auth.uid || isAdmin() || isRole('GUEPARDO'));
      allow create: if isAuthenticated() && isValidAppointment(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Commissions collection
    match /commissions/{commissionId} {
      allow read: if isAuthenticated() && (resource.data.guepardoUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (isRole('GUEPARDO') || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Collection History collection
    match /collections_history/{historyId} {
      allow read: if isAuthenticated() && (resource.data.guepardoUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (isRole('GUEPARDO') || isAdmin());
      allow update: if isAuthenticated() && (resource.data.guepardoUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Waitlist collection
    match /waitlist/{waitlistId} {
      allow read: if isAuthenticated() && (resource.data.userUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated(); // Simplified for prototype, ideally validate data
      allow update, delete: if isAdmin();
    }
  }
}
